# Indexer configuration
ALCHEMY_API_KEY=your-api-key-here

# Merkle CLI (build/query): optional override for default asset id
# MERKLE_ASSET_ID=1

# Merkle batch prep concurrency (p-limit); 1 = flush each batch as soon as it is full.
# >1 buffers that many full batches before prep+flush (works with small fetch pages).
# MERKLE_BATCH_CONCURRENCY=4

# Indexer /transactions page_size (optional; default auto caps at 2000 rows per request)
# MERKLE_FETCH_PAGE_SIZE=2000
